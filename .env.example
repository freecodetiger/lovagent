# Optional env-first deployment.
# For most users, start the app first and finish configuration in /setup.

# Model
ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_MODEL=glm-5
ZHIPU_THINKING_TYPE=disabled
ZHIPU_WEB_SEARCH_ENABLED=true

# WeCom
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
PUBLIC_BASE_URL=

# Database
DATABASE_TYPE=sqlite
DATABASE_PATH=./girlchat.db

# Admin
ADMIN_PASSWORD=change_me_if_you_skip_setup
ADMIN_COOKIE_NAME=lovagent_admin_session
ADMIN_SESSION_SECRET=replace_with_a_random_secret_for_production
ADMIN_DEV_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
